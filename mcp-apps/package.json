{
  "name": "ghl-mcp-apps",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Companion MCP Apps for the GoHighLevel MCP server",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/main.js",
  "bin": {
    "ghl-mcp-apps": "dist/main.js"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.server.json",
    "dev": "tsx watch main.ts",
    "start": "node dist/main.js",
    "start:stdio": "node dist/main.js --stdio",
    "start:http": "node dist/main.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^22.15.29",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-singlefile": "^2.3.0",
    "tsx": "^4.20.6"
  }
}
