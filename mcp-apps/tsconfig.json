{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["node"],
    "noEmit": true
  },
  "include": ["src/**/*", "server.ts", "main.ts", "vite.config.ts"]
}
